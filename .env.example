# Vercel 公開時の簡易パスワード保護（未設定なら認証なし）
# SITE_PASSWORD=

# Vercel から字幕取得する場合: 自宅 PC で npm run relay を起動し、
# Cloudflare Tunnel 等で公開した URL を設定（推奨）
# TRANSCRIPT_RELAY_URL=https://xxxx.trycloudflare.com
# TRANSCRIPT_RELAY_SECRET=任意の共有秘密

# 住宅用プロキシ（Webshare Residential 等）を使う場合（任意）
# TRANSCRIPT_PROXY_URL=http://user:pass@host:port

# Google AI Studio で無料取得: https://aistudio.google.com/apikey
# 設定後: npm run check:gemini
GEMINI_API_KEY=

# Gemini モデル ID（変更時はここだけ更新）
GEMINI_MODEL=gemini-2.5-flash

# Turso（本番・複数端末共有）
# 未設定時は file:data/sessions.db（ローカルファイル）にフォールバック
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=

# yt-dlp 実行ファイル（PATH にある場合は yt-dlp のままで可）
YTDLP_PATH=yt-dlp

# ブラウザ Cookie（429 回避用）。edge / chrome / none
# Edge が起動中だと Cookie 読み取りに失敗することがあります
YTDLP_COOKIES_BROWSER=none
