{
  "name": "video-summary-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "check:gemini": "node scripts/check-gemini.mjs",
    "check:turso": "node scripts/check-turso.mjs",
    "db:init": "node scripts/db-init.mjs",
    "db:migrate-local": "node scripts/migrate-to-turso.mjs",
    "relay": "node scripts/transcript-relay.mjs",
    "diagram:open": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-vidnote-diagram.ps1",
    "diagram:shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-vidnote-diagram-shortcut.ps1",
    "diagram:import": "npx --yes tsx scripts/import-diagram-cli.ts",
    "diagram:watch": "node scripts/watch-diagram.mjs",
    "diagram:session-target": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/copy-session-target.ps1"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@google/generative-ai": "^0.24.1",
    "@libsql/client": "^0.17.4",
    "@tiptap/extension-color": "^2.26.1",
    "@tiptap/extension-text-style": "^2.26.1",
    "@tiptap/react": "^2.26.1",
    "@tiptap/starter-kit": "^2.26.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "undici": "^8.5.0",
    "youtube-transcript": "^1.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
